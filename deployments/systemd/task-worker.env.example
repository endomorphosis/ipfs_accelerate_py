# Optional TaskQueue worker overrides.
# Copy to: /etc/ipfs-accelerate/task-worker.env
#
# This file is loaded by:
# - deployments/systemd/ipfs-accelerate-task-worker.service (standalone worker)
# - deployments/systemd/ipfs-accelerate.service (primary MCP service)
# - deployments/systemd/ipfs-accelerate-mcp.service (secondary MCP++ service)
# Keep secrets (tokens/keys) in /etc/ipfs-accelerate/secrets.env instead.

# Session tagging (required for strict session routing)
# IPFS_ACCELERATE_PY_TASK_P2P_SESSION=S_A
# IPFS_DATASETS_PY_TASK_P2P_SESSION=S_A

# Session failover (default-on in code):
# If a queued task requires a different session_id and the matching session peer
# is unavailable/too slow to drain it, the local worker will resubmit it locally
# after this delay.
#
# To disable failover entirely:
# IPFS_ACCELERATE_PY_TASK_P2P_SESSION_FAILOVER=0
# IPFS_DATASETS_PY_TASK_P2P_SESSION_FAILOVER=0
#
# Conservative defaults are set in the unit files; override here if desired:
# IPFS_ACCELERATE_PY_TASK_P2P_SESSION_FAILOVER_AFTER_S=240
# IPFS_DATASETS_PY_TASK_P2P_SESSION_FAILOVER_AFTER_S=240

# Optional tuning:
# IPFS_ACCELERATE_PY_TASK_P2P_SESSION_FAILOVER_SCAN_INTERVAL_S=2
# IPFS_ACCELERATE_PY_TASK_P2P_SESSION_FAILOVER_MAX_PER_SCAN=2

# Discovery noise control (recommended for single-host/LAN deployments):
# disable public bootstrap + DHT/rendezvous to avoid repeated libp2p
# secure-handshake failures against incompatible peers.
# mDNS is also disabled by default in unit files; opt-in only on trusted LANs.
# IPFS_ACCELERATE_PY_TASK_P2P_BOOTSTRAP_PEERS=off
# IPFS_DATASETS_PY_TASK_P2P_BOOTSTRAP_PEERS=off
# IPFS_ACCELERATE_PY_TASK_P2P_DHT=0
# IPFS_DATASETS_PY_TASK_P2P_DHT=0
# IPFS_ACCELERATE_PY_TASK_P2P_RENDEZVOUS=0
# IPFS_DATASETS_PY_TASK_P2P_RENDEZVOUS=0
# IPFS_ACCELERATE_PY_TASK_P2P_MDNS=0
# IPFS_DATASETS_PY_TASK_P2P_MDNS=0
# IPFS_ACCELERATE_PY_TASK_P2P_AUTONAT=0
# IPFS_DATASETS_PY_TASK_P2P_AUTONAT=0
# IPFS_ACCELERATE_PY_TASK_P2P_RELAY=0
# IPFS_DATASETS_PY_TASK_P2P_RELAY=0
# IPFS_ACCELERATE_PY_TASK_P2P_HOLEPUNCH=0
# IPFS_DATASETS_PY_TASK_P2P_HOLEPUNCH=0

# To re-enable WAN discovery later, set one or more of:
# IPFS_ACCELERATE_PY_TASK_P2P_BOOTSTRAP_PEERS=<comma-separated multiaddrs>
# IPFS_ACCELERATE_PY_TASK_P2P_DHT=1
# IPFS_ACCELERATE_PY_TASK_P2P_RENDEZVOUS=1
# To re-enable LAN mDNS discovery, set:
# IPFS_ACCELERATE_PY_TASK_P2P_MDNS=1
# To re-enable NAT traversal helpers, set one or more of:
# IPFS_ACCELERATE_PY_TASK_P2P_AUTONAT=1
# IPFS_ACCELERATE_PY_TASK_P2P_RELAY=1
# IPFS_ACCELERATE_PY_TASK_P2P_HOLEPUNCH=1

# Autoscale knobs (examples)
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_MAX=8
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_IDLE_S=60
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_REMOTE=0
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_PROCESSES=0

# Cross-peer drain defaults used by the systemd units:
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE=1
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_MIN=1
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_MAX=4
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_POLL_S=2
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_REMOTE=1
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_REMOTE_REFRESH_S=5
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_REMOTE_MAX_PEERS=10
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_MESH_CHILDREN=1
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_PROCESSES=0
# IPFS_ACCELERATE_PY_TASK_WORKER_MESH_PEER_FANOUT=4
# IPFS_ACCELERATE_PY_TASK_WORKER_MESH_CLAIM_BATCH=16
# IPFS_ACCELERATE_PY_TASK_WORKER_LOCAL_CLAIM_BATCH=16
# IPFS_ACCELERATE_PY_TASK_WORKER_ENABLE_HF=1
# IPFS_ACCELERATE_PY_TASK_WORKER_MINIMAL_HF=1
# IPFS_ACCELERATE_PY_TASK_WORKER_TEXTGEN_BATCH_MAX=4
# IPFS_ACCELERATE_PY_TASK_WORKER_TEXT2TEXT_BATCH_MAX=8
# IPFS_ACCELERATE_PY_TASK_WORKER_TEXTCLS_BATCH_MAX=16
# IPFS_ACCELERATE_PY_TASK_WORKER_EMBED_BATCH_MAX=16
