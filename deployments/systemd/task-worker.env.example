# Optional TaskQueue worker overrides.
# Copy to: /etc/ipfs-accelerate/task-worker.env
#
# This file is loaded by:
# - deployments/systemd/ipfs-accelerate-task-worker.service (standalone worker)
# - deployments/systemd/ipfs-accelerate.service (primary MCP service)
# - deployments/systemd/ipfs-accelerate-mcp.service (secondary MCP++ service)
# Keep secrets (tokens/keys) in /etc/ipfs-accelerate/secrets.env instead.

# Session tagging (required for strict session routing)
# IPFS_ACCELERATE_PY_TASK_P2P_SESSION=S_A
# IPFS_DATASETS_PY_TASK_P2P_SESSION=S_A

# Session failover (default-on in code):
# If a queued task requires a different session_id and the matching session peer
# is unavailable/too slow to drain it, the local worker will resubmit it locally
# after this delay.
#
# To disable failover entirely:
# IPFS_ACCELERATE_PY_TASK_P2P_SESSION_FAILOVER=0
# IPFS_DATASETS_PY_TASK_P2P_SESSION_FAILOVER=0
#
# Conservative defaults are set in the unit files; override here if desired:
# IPFS_ACCELERATE_PY_TASK_P2P_SESSION_FAILOVER_AFTER_S=240
# IPFS_DATASETS_PY_TASK_P2P_SESSION_FAILOVER_AFTER_S=240

# Optional tuning:
# IPFS_ACCELERATE_PY_TASK_P2P_SESSION_FAILOVER_SCAN_INTERVAL_S=2
# IPFS_ACCELERATE_PY_TASK_P2P_SESSION_FAILOVER_MAX_PER_SCAN=2

# Autoscale knobs (examples)
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_MAX=8
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_IDLE_S=60
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_REMOTE=0
# IPFS_ACCELERATE_PY_TASK_WORKER_AUTOSCALE_PROCESSES=0
