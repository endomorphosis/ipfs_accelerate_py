# MCP++ Server Configuration
# Copy to .env and customize for your deployment

# --- Server ---
MCP_SERVER_NAME=ipfs-accelerate-mcp-trio
MCP_HOST=0.0.0.0
MCP_PORT=3003
MCP_MOUNT_PATH=/mcp
MCP_DEBUG=0
MCP_DISABLE_P2P=0
MCP_LOG_FORMAT=text  # "text" or "json" (structured)

# --- Rate Limiting ---
MCPPP_RATE_LIMIT_RPS=50       # Requests per second per IP
MCPPP_RATE_LIMIT_BURST=100    # Max burst size per IP

# --- ZK DAG Compaction ---
MCPPP_EPOCH_SIZE=1000          # Events per compaction epoch
MCPPP_HOT_TIER_MAX=2000        # Max events in hot tier before compaction
MCPPP_STORAGE_DIR=.mcppp       # Directory for cold tier + state files

# --- Execution ---
MCPPP_EXEC_TIMEOUT_S=30        # Tool execution timeout (seconds)

# --- Security ---
MCPPP_ALLOW_UNSIGNED_DELEGATIONS=0   # 0=deny unsigned, 1=allow (dev only)
MCPPP_REQUIRE_SERVICE_SIGNATURES=0   # 0=accept all, 1=verify HMAC on announces

# --- CORS (comma-separated origins, or * for all) ---
MCP_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
